# ── Server ─────────────────────────────────────────────────────────────────
# MySQL connection string
DATABASE_URL=mysql://user:password@localhost:3306/stemsplitter

# JWT secret for session cookies (generate with: openssl rand -base64 32)
JWT_SECRET=

# OAuth server base URL
OAUTH_SERVER_URL=

# Manus app identifiers
VITE_APP_ID=
OWNER_OPEN_ID=

# Forge / S3-compatible storage
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Server port (optional, defaults to 3000)
PORT=3000

# ── Client (EXPO_PUBLIC_ prefix exposes to the JS bundle) ──────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_OAUTH_PORTAL_URL=
EXPO_PUBLIC_OAUTH_SERVER_URL=
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_OWNER_OPEN_ID=
EXPO_PUBLIC_OWNER_NAME=
